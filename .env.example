# Design Diagnosis App — Environment Configuration
# Copy this file to .env and fill in your actual values

# SendGrid Email Service
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=your-email@example.com

# Stripe Payment Processing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Anthropic Claude API (for Vision Analysis)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# Admin Access (for private endpoints)
ADMIN_API_KEY=your_secure_admin_key_here

# Database Configuration
DB_PATH=design_diagnosis.db
REPORT_OUTPUT_DIR=./reports

# Mailchimp Integration (optional, for future use)
# MAILCHIMP_API_KEY=your_mailchimp_api_key
# MAILCHIMP_AUDIENCE_ID=your_mailchimp_audience_id

# Base URL (optional, will auto-detect from requests)
# BASE_URL=http://147.182.247.168:8000

# Amazon Affiliate ID (optional, for shopping list links)
# AMAZON_AFFILIATE_ID=your_affiliate_id
